# Required for OpenClaw
OPENAI_API_KEY=

# Required for Splunk Observability Cloud
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=replace-me

# Recommended lab settings
K8S_CLUSTER_NAME=openclaw-lab
OPENCLAW_NAMESPACE=openclaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_SERVICE_NAME=openclaw
OPENCLAW_DEPLOYMENT_ENVIRONMENT=Openclaw
OPENCLAW_NODE_OPTIONS_BASE=--max-old-space-size=1536
OPENCLAW_MEMORY_REQUEST=1Gi
OPENCLAW_MEMORY_LIMIT=2Gi
SPLUNK_OTEL_NAMESPACE=splunk-o11y
SPLUNK_OTEL_RELEASE_NAME=splunk-otel
SPLUNK_ENVIRONMENT=lab
SPLUNK_ENABLE_PROFILING=true

# Optional if you want to reuse an existing collector/operator install
# SKIP_SPLUNK_OTEL_INSTALL=true
# SPLUNK_INSTRUMENTATION_REF=otel-splunk/splunk-otel-collector

# Optional if the cluster default storage class is missing or wrong
# OPENCLAW_STORAGE_CLASS=gp2

# Optional if you want the Splunk chart to use explicit cluster metadata
# K8S_DISTRIBUTION=eks
# K8S_CLOUD_PROVIDER=aws

# Optional if you want to pin the chart
# SPLUNK_OTEL_CHART_VERSION=0.147.1
