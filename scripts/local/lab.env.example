# Required for OpenAI-backed local inference
OPENAI_API_KEY=

# Required only if this repo needs to start its own local collector container
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=replace-me

# Optional local bootstrap settings
NEMOCLAW_SANDBOX_NAME=my-assistant
NEMOCLAW_REPO_DIR=/tmp/NemoClaw
LOCAL_OPENSHELL_GATEWAY_NAME=nemoclaw
LOCAL_OPENAI_MODEL=gpt-4.1-mini
# Leave unset to use the host-local OpenAI relay through the OpenShell gateway
LOCAL_OPENAI_BASE_URL=
LOCAL_OPENAI_RELAY_PORT=8787
LOCAL_GATEWAY_HOST_ALIAS=host.docker.internal
LOCAL_GATEWAY_HOST_IP=192.168.65.254
LOCAL_EXTRA_CA_FILE=
LOCAL_EXTRA_CA_COMMON_NAME=
LOCAL_OTEL_COLLECTOR_CONTAINER_NAME=openclaw-local-otel-collector
LOCAL_OTEL_COLLECTOR_IMAGE=quay.io/signalfx/splunk-otel-collector:latest
LOCAL_OTEL_COLLECTOR_HOST_PORT=4318
LOCAL_OTEL_COLLECTOR_GRPC_PORT=4317
LOCAL_OTEL_COLLECTOR_HEALTH_PORT=13133
LOCAL_OTEL_FORWARDER_NAME=openclaw-otlp-forwarder
LOCAL_OTEL_FORWARDER_NAMESPACE=openshell
LOCAL_OTEL_FORWARDER_IMAGE=otel/opentelemetry-collector-contrib:0.126.0
LOCAL_OTEL_FORWARDER_HTTP_PORT=4318
LOCAL_OTEL_FORWARDER_HOST_PORT=43181
LOCAL_OTEL_FORWARDER_HEALTH_PORT=13181
OPENCLAW_DEPLOYMENT_ENVIRONMENT=Openclaw
OPENCLAW_NODE_OPTIONS_BASE=--max-old-space-size=1536
