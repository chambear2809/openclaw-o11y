# Required for OpenAI-backed local inference
OPENAI_API_KEY=

# Required only if this repo needs to start its own local collector container
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=replace-me

# Optional local bootstrap settings
NEMOCLAW_SANDBOX_NAME=my-assistant
NEMOCLAW_REPO_DIR=/tmp/NemoClaw
NEMOCLAW_REF=b36a673a3f031e490c5348a9061c8e34fa00d26a
# Optional override if you need to source NemoClaw from a fork instead of NVIDIA/NemoClaw
# NEMOCLAW_REPO_URL=https://github.com/NVIDIA/NemoClaw.git
LOCAL_OPENSHELL_GATEWAY_NAME=nemoclaw
LOCAL_OPENAI_MODEL=gpt-4.1-mini
LOCAL_OPENAI_SMOKE_STUB_MODEL=openclaw-smoke-stub
LOCAL_OPENAI_RELAY_SERVICE_NAME=openai-relay
LOCAL_SPLUNK_OTEL_JS_VERSION=4.0.0
LOCAL_SPLUNK_OTEL_PYTHON_VERSION=2.9.0
# Bounds the secondary live-provider smoke path; the default stub smoke is deterministic and fast.
LOCAL_OPENAI_SMOKE_TIMEOUT_SECONDS=45
# Leave unset to use the host-local OpenAI relay through the OpenShell gateway
LOCAL_OPENAI_BASE_URL=
LOCAL_OPENAI_RELAY_PORT=8787
# Leave unset to auto-detect a gateway-reachable host alias or IP from inside the OpenShell container
LOCAL_GATEWAY_HOST_ALIAS=
LOCAL_GATEWAY_HOST_IP=
# Also used to extend trust for the repo-managed local OTEL collector when outbound TLS is intercepted.
LOCAL_EXTRA_CA_FILE=
LOCAL_EXTRA_CA_COMMON_NAME=
LOCAL_OTEL_COLLECTOR_CONTAINER_NAME=openclaw-local-otel-collector
LOCAL_OTEL_COLLECTOR_IMAGE=quay.io/signalfx/splunk-otel-collector:0.126.0
LOCAL_OTEL_COLLECTOR_HOST_PORT=4318
LOCAL_OTEL_COLLECTOR_GRPC_PORT=4317
LOCAL_OTEL_COLLECTOR_HEALTH_PORT=13133
LOCAL_AGENT_SANDBOX_NAMESPACE=agent-sandbox-system
LOCAL_AGENT_SANDBOX_CONTROLLER_SERVICE_NAME=agent-sandbox-controller
LOCAL_AGENT_SANDBOX_METRICS_SERVICE_NAME=agent-sandbox-controller
LOCAL_AGENT_SANDBOX_METRICS_BRIDGE_PORT=19090
LOCAL_OTEL_FORWARDER_NAME=openclaw-otlp-forwarder
LOCAL_OTEL_FORWARDER_NAMESPACE=openshell
LOCAL_OTEL_FORWARDER_IMAGE=otel/opentelemetry-collector-contrib:0.126.0
LOCAL_OTEL_FORWARDER_HTTP_PORT=4318
LOCAL_OTEL_FORWARDER_HOST_PORT=43181
LOCAL_OTEL_FORWARDER_HEALTH_PORT=13181
OPENCLAW_DEPLOYMENT_ENVIRONMENT=nemolaw
OPENCLAW_NODE_OPTIONS_BASE=--max-old-space-size=1536
